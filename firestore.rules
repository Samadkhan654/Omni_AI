rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default safety catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Basic structural validation helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.]+$');
    }

    function isSafeString(str, max_len) {
      return str is string && str.size() <= max_len;
    }

    // Profiles rules: storing role, avatar and business stats
    match /profiles/{profileId} {
      allow read: if true;
      allow write: if true;
    }

    // Customers collection rules
    match /customers/{customerId} {
      allow read: if true;
      allow write: if true;
    }

    // Products inventory collection rules
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    // Profit leaks tracking rules
    match /leaks/{leakId} {
      allow read: if true;
      allow write: if true;
    }

    // Synced contacts collection rules
    match /contacts/{contactId} {
      allow read: if true;
      allow write: if true;
    }

    // Messages database rules for Aria
    match /messages/{messageId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
